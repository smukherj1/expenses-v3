{
  "name": "expenses-backend",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --outfile dist/server --compile",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "papaparse": "^5.4.1",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/papaparse": "^5.3.14",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
