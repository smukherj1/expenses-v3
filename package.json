{
  "name": "expenses-v3",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "test:backend": "bun test tests/backend.test.ts",
    "test:frontend": "bun test --timeout 30000 tests/frontend.test.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "bun run typecheck && bun run --cwd frontend typecheck && bun run --cwd backend typecheck",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "fix:all": "bun run format && bun run lint:fix && bun run --cwd frontend lint:fix && bun run --cwd backend lint:fix"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "eslint": "^10.2.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
